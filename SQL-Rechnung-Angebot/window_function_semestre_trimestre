-- Window function
SELECT *
    FROM (
        SELECT
            SUM(profit) OVER (PARTITION BY product ORDER BY profit DESC) AS total
            ROW_NUMBER() OVER (PARTITION BY product ORDER BY profit DESC) AS row_number
            FROM sales
    ) AS temp
    WHERE t.row_number < 4
--- Equivalent
SELECT *
    FROM (
        SELECT
            SUM(profit) OVER w AS total
            ROW_NUMBER() OVER w AS row_number
            FROM sales
            WINDOW w AS (PARTITION BY product ORDER BY profit DESC)
    ) AS temp
    WHERE t.row_number < 4

-- Semestre   1)
SELECT
    (CASE WHEN DATEPART(quarter,invoice_date) >= 3 THEN 'S2' ELSE 'S1' END) AS semester,
    SUM(amount) AS revenue
    FROM invoice
    WHERE YEAR(invoice_date) = YEAR(GETDATE())
    GROUP BY (CASE WHEN DATEPART(quarter,invoice_date) >= 3 THEN 'H2' ELSE 'H1' END)  

-- Semestre 2
SELECT IIF(MONTH(invoiceDate) < 7 ,'H1','H2') AS halbjahr,
        YEAR(invoiceDate) AS jahr,
        SUM(amount) AS Umsatz
        FROM invoice
        WHERE YEAR(invoiceDate) = YEAR(GETDATE()) - 1  
        GROUP BY  YEAR(invoiceDate),IIF(MONTH(invoiceDate) <7 ,'H1','H2')

-- Trimestre

SELECT CONCAT('Q',DATEPART(quarter,invoice_date))  AS quarter,
        YEAR(invoice_date) AS year,
        SUM(amount) AS revenue
        FROM invoice
        WHERE YEAR(invoice_date) = YEAR(GETDATE())
        GROUP BY  DATEPART(quarter,invoice_date),YEAR(invoice_date) 
